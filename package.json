  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
