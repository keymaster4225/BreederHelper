{
  "name": "breedwise",
  "version": "1.3.7",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:release": "bash scripts/build-release.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:screen": "jest --runInBand",
    "test:coverage:unit": "vitest run --coverage",
    "test:coverage:screen": "jest --runInBand --coverage",
    "test:coverage": "npm run test:coverage:unit && npm run test:coverage:screen",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "babel-preset-expo": "~55.0.0",
    "bubblewrap": "^0.2.0",
    "expo": "~55.0.15",
    "expo-asset": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-localization": "~55.0.13",
    "expo-sharing": "~55.0.18",
